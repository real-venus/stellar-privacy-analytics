{
  "name": "@stellar/backend",
  "version": "1.0.0",
  "description": "Privacy-first backend API for Stellar ecosystem",
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:load": "ts-node src/testing/runLoadTest.ts",
    "test:load:light": "ts-node src/testing/runLoadTest.ts --scenario light",
    "test:load:moderate": "ts-node src/testing/runLoadTest.ts --scenario moderate",
    "test:load:heavy": "ts-node src/testing/runLoadTest.ts --scenario heavy",
    "test:load:peak": "ts-node src/testing/runLoadTest.ts --scenario peak",
    "capacity:plan": "ts-node src/testing/runCapacityPlanner.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/__tests__/**/*.test.ts", "**/*.test.ts"],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "clearMocks": true
  },
  "dependencies": {
    "@stellar/shared": "file:../shared",
    "bcryptjs": "^2.4.3",
    "bullmq": "^4.15.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "geoip-lite": "^1.4.10",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.0.1",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "prom-client": "^15.0.0",
    "redis": "^4.6.10",
    "socket.io": "^4.8.3",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "ipfs-http-client": "^60.0.1",
    "axios": "^1.6.2",
    "form-data": "^4.0.0",
    "jsbn": "^1.1.0",
    "http-proxy-middleware": "^2.0.6",
    "rate-limiter-flexible": "^4.0.1",
    "lru-cache": "^10.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/geoip-lite": "^1.4.4",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/pg": "^8.10.10",
    "@types/multer": "^1.4.12",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.10.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "eslint": "^8.54.0",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0"
  }
}
